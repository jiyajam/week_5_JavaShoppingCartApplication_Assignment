<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="cart.MainController"
      spacing="10">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <HBox spacing="10">
        <Label fx:id="selectLangLabel" text="Select Language"/>
        <ComboBox fx:id="languageBox"/>
        <Button fx:id="confirmBtn" text="Confirm" onAction="#changeLanguage"/>
    </HBox>

    <HBox spacing="10">
        <Label fx:id="enterItemsLabel" text="Enter items"/>
        <TextField fx:id="itemCountField"/>
        <Button fx:id="generateBtn" text="Generate" onAction="#generateItemFields"/>
    </HBox>

    <VBox fx:id="itemsContainer" spacing="5"/>

    <Button fx:id="calculateBtn" text="Calculate" onAction="#calculateTotal"/>

    <Label fx:id="totalLabel" text="0.00"/>
</VBox>